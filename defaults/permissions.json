{
  "_comment": "Default permission rules for Attar-Code. Copy to .attar-code/permissions.json to customize per-project.",
  "defaultMode": "supervised",
  "allow": [
    "read:*",
    "bash:git status",
    "bash:git log *",
    "bash:git diff *",
    "bash:git branch *",
    "bash:npm test",
    "bash:npm run build",
    "bash:npm run lint",
    "bash:npx vitest *",
    "bash:npx jest *",
    "bash:npx tsc *",
    "bash:python -m pytest *",
    "bash:cargo test *",
    "bash:cargo build *",
    "bash:go test *",
    "bash:go build *",
    "bash:dotnet test",
    "bash:dotnet build"
  ],
  "ask": [
    "bash:npm install *",
    "bash:pip install *",
    "bash:cargo install *",
    "bash:composer install *",
    "bash:dotnet add *",
    "bash:git push *",
    "bash:git commit *",
    "delete:*",
    "bash:docker *",
    "edit:.env*"
  ],
  "deny": [
    "bash:sudo *",
    "bash:rm -rf /",
    "bash:rm -rf ~",
    "bash:rm -rf /*",
    "bash:mkfs *",
    "bash:dd if=*",
    "bash::(){ :|:& };:",
    "bash:shutdown *",
    "bash:reboot *",
    "bash:curl * | bash",
    "bash:curl * | sh",
    "bash:wget * | bash",
    "bash:wget * | sh",
    "edit:*.pem",
    "edit:*.key",
    "edit:*credentials*",
    "edit:*id_rsa*"
  ],
  "autonomousErrorBudget": 3,
  "maxActionsBeforeCheckin": 50,
  "gitCheckpointBeforeMultiFileChange": true
}
